# Port configuration
PORT=8000

# Database URL for MySQL (Prisma format)
# Replace user, password, host, port, and database name with your MySQL configuration
DATABASE_URL="mysql://root:password@localhost:3306/ouroboros_custom"

# JWT configuration
JWT_SECRET="super-secret-key-change-this-in-production"
JWT_REFRESH_SECRET="another-super-secret-key-change-this-in-production"
JWT_ACCESS_EXPIRATION="15m"
JWT_REFRESH_EXPIRATION="7d"
